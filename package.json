{
  "name": "parlamentum",
  "version": "1.0.0",
  "description": "Sistema de gestión parlamentaria profesional",
  "author": {
    "name": "Jose Moreno",
    "email": "joseamorenoc025@gmail.com"
  },
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build && electron-builder",
    "build:win": "npm run build -- --win",
    "build:mac": "npm run build -- --mac",
    "db:migrate": "node electron/src/db/migrate.js",
    "db:seed": "node electron/src/db/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:report": "npm run test:coverage && echo '📊 Reporte generado en coverage/index.html'",
    "test:e2e": "playwright test",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "lint": "eslint src electron --ext .js,.jsx",
    "prepare": "husky",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.17.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.1",
    "winston": "^3.13.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^21.0.2",
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "electron": "^40.10.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.5",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "tar": "^7.5.11",
    "esbuild": "^0.25.0",
    "app-builder-lib": "^26.8.1",
    "dmg-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "node-gyp": "^12.0.0"
  },
  "build": {
    "appId": "com.parlamentum.app",
    "productName": "PARLAMENTUM",
    "publish": [
      {
        "provider": "github",
        "owner": "joseamorenoc025",
        "repo": "parlamentum"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md}"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-win.${ext}",
      "icon": "public/logo.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-mac.${ext}",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}-linux.${ext}"
    }
  }
}
