{
  "name": "segundo-cerebro-legislativo",
  "version": "1.0.0",
  "description": "Sistema de gestión legislativa profesional",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build && electron-builder",
    "build:win": "npm run build -- --win",
    "build:mac": "npm run build -- --mac",
    "db:migrate": "node electron/src/db/migrate.js",
    "db:seed": "node electron/src/db/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:report": "npm run test:coverage && echo '📊 Reporte generado en coverage/index.html'",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "lint": "eslint src electron --ext .js,.jsx",
    "prepare": "husky"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.469.0",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.1",
    "winston": "^3.13.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "vite": "^5.2.12",
    "vitest": "^4.1.5",
    "wait-on": "^7.2.0"
  }
}
